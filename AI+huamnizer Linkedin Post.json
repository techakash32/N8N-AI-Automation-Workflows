        "jsonBody": "={\n  \"model\": \"meta/llama3-70b-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a LinkedIn editor. Make posts more human and conversational. Remove AI-sounding phrases. Return ONLY improved post. No explanations.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Humanize this LinkedIn post: {{ JSON.stringify($json.content).slice(1, -1) }}\"\n    }\n  ],\n  \"temperature\": 0.5,\n  \"max_tokens\": 800\n}",
        "options": {}
